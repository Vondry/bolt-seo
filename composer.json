{
    "name": "appolodev/bolt-seo",
    "description": "Bolt - Seo extension",
    "type": "bolt-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "AppoloDev",
            "email": "contact@appolo.fr"
        }
    ],
    "require": {
        "php": ">=8.2",
        "twig/twig": "^3.21"
    },
    "require-dev": {
        "bolt/core": "^6.1.3",
        "phpstan/phpstan": "2.1.33",
        "rector/rector": "2.2.14",
        "symplify/easy-coding-standard": "^13",
        "phpstan/phpstan-symfony": "2.0.9",
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Appolo\\BoltSeo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Appolo\\BoltSeo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "entrypoint": "Appolo\\BoltSeo\\Extension"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": true,
            "drupol/composer-packages": true
        }
    }
}
